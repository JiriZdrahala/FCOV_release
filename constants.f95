      function Levi()result(res)
         integer res(0:4,0:4,0:4)
         
         res=0
         do i = 1,3
            do j = 1,3
               do k = 1,3
                  if(i/=j .and. j/=k .and. k/=i)then
                     if(i-j==-1 .or. i-j==2)then
                        res(i,j,k)=1
                     else if(i-j==-2 .or. i-j==1)then
                        res(i,j,k)=-1
                     end if
                  end if
               end do
            end do
         end do
         
      end function Levi
      
